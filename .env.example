# Copia este archivo a .env y rellena los valores.
# Nunca subas .env a Git (ya está en .gitignore).

PORT=3780

# ImgBB — solo en servidor; el navegador no la ve.
IMGBB_API_KEY=

# EmailJS (clave pública + IDs; siguen siendo visibles en el navegador al cargar la página)
EMAILJS_PUBLIC_KEY=
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=

# reCAPTCHA v3 — site key pública (la clave secreta solo en backend si verificas en servidor)
RECAPTCHA_SITE_KEY=

# Enlaces / WhatsApp (sin + ni espacios, ej: 573001234567)
WHATSAPP_PHONE=
INSTAGRAM_URL=
FACEBOOK_URL=
